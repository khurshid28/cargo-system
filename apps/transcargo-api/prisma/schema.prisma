// TransCargo Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SENDER
  DRIVER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum CargoRequestStatus {
  CREATED
  MATCHING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CLOSED
  CANCELLED
}

enum DriverAvailability {
  OFFLINE
  ONLINE
  BUSY
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  phone        String     @unique
  fullName     String?
  role         UserRole
  status       UserStatus @default(ACTIVE)
  language     String     @default("uz")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  driverProfile DriverProfile?
  vehicles      Vehicle[]
  sentRequests  CargoRequest[] @relation("SenderRequests")
  drivenRequests CargoRequest[] @relation("DriverRequests")
  messagesSent  ChatMessage[]  @relation("MessageSender")
  ratingsGiven  Rating[]       @relation("RatingFrom")
  ratingsReceived Rating[]     @relation("RatingTo")

  @@index([role, status])
}

model DriverProfile {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String             @unique @db.Uuid
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String?
  passportNumber  String?
  verifiedAt      DateTime?
  availability    DriverAvailability @default(OFFLINE)
  /// Last known location (lat, lng). Stored as separate columns for portability;
  /// PostGIS geography column added via custom migration for matching queries.
  lastLat         Float?
  lastLng         Float?
  lastSeenAt      DateTime?
  rating          Float              @default(0)
  ratingCount     Int                @default(0)

  @@index([availability])
}

model Vehicle {
  id           String   @id @default(uuid()) @db.Uuid
  ownerId      String   @db.Uuid
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  plate        String   @unique
  bodyKind     String   // tipper, flatbed, tent, refrigerator, ...
  capacityKg   Int
  volumeM3     Float?
  photos       String[] @default([])
  techPassport String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cargoRequests CargoRequest[]
}

model CargoRequest {
  id           String             @id @default(uuid()) @db.Uuid
  /// External order id from MaterialMarket (when integration originated there)
  externalOrderId String?         @db.Uuid
  senderId     String             @db.Uuid
  sender       User               @relation("SenderRequests", fields: [senderId], references: [id])
  driverId     String?            @db.Uuid
  driver       User?              @relation("DriverRequests", fields: [driverId], references: [id])
  vehicleId    String?            @db.Uuid
  vehicle      Vehicle?           @relation(fields: [vehicleId], references: [id])

  status       CargoRequestStatus @default(CREATED)

  pickupAddress  String
  pickupLat      Float
  pickupLng      Float
  dropoffAddress String
  dropoffLat     Float
  dropoffLng     Float

  cargoType    String
  weightKg     Float
  volumeM3     Float?
  bodyKind     String?
  notes        String?

  priceAmount  Float?
  priceCurrency String?  @default("UZS")

  scheduledAt  DateTime?
  pickedUpAt   DateTime?
  deliveredAt  DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trackingPoints TrackingPoint[]
  messages       ChatMessage[]
  ratings        Rating[]
  payments       Payment[]

  @@index([status])
  @@index([externalOrderId])
}

model TrackingPoint {
  id             String       @id @default(uuid()) @db.Uuid
  cargoRequestId String       @db.Uuid
  cargoRequest   CargoRequest @relation(fields: [cargoRequestId], references: [id], onDelete: Cascade)
  lat            Float
  lng            Float
  speedKph       Float?
  recordedAt     DateTime     @default(now())

  @@index([cargoRequestId, recordedAt])
}

model ChatMessage {
  id             String       @id @default(uuid()) @db.Uuid
  cargoRequestId String       @db.Uuid
  cargoRequest   CargoRequest @relation(fields: [cargoRequestId], references: [id], onDelete: Cascade)
  senderId       String       @db.Uuid
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  body           String
  createdAt      DateTime     @default(now())

  @@index([cargoRequestId, createdAt])
}

model Rating {
  id             String       @id @default(uuid()) @db.Uuid
  cargoRequestId String       @db.Uuid
  cargoRequest   CargoRequest @relation(fields: [cargoRequestId], references: [id], onDelete: Cascade)
  fromUserId     String       @db.Uuid
  fromUser       User         @relation("RatingFrom", fields: [fromUserId], references: [id])
  toUserId       String       @db.Uuid
  toUser         User         @relation("RatingTo", fields: [toUserId], references: [id])
  stars          Int
  comment        String?
  createdAt      DateTime     @default(now())

  @@unique([cargoRequestId, fromUserId, toUserId])
}

enum PaymentProvider {
  CLICK
  PAYME
  UZUM
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Payment {
  id             String          @id @default(uuid()) @db.Uuid
  cargoRequestId String          @db.Uuid
  cargoRequest   CargoRequest    @relation(fields: [cargoRequestId], references: [id], onDelete: Cascade)
  provider       PaymentProvider
  status         PaymentStatus   @default(PENDING)
  amount         Float
  currency       String          @default("UZS")
  externalId     String?
  payloadJson    Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
}

/// Outbox pattern: events to be published to RabbitMQ atomically with DB writes.
model OutboxEvent {
  id          String   @id @default(uuid()) @db.Uuid
  routingKey  String
  payload     Json
  publishedAt DateTime?
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([publishedAt])
}

/// Idempotency: dedupe inbound events by their event_id.
model InboxEvent {
  eventId    String   @id @db.Uuid
  routingKey String
  receivedAt DateTime @default(now())
}
