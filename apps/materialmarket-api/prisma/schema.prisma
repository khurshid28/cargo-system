// MaterialMarket Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  MERCHANT
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum OrderStatus {
  CREATED
  CONFIRMED
  SHIPPING
  DELIVERED
  CLOSED
  CANCELLED
}

model User {
  id        String     @id @default(uuid()) @db.Uuid
  phone     String     @unique
  fullName  String?
  role      UserRole
  status    UserStatus @default(ACTIVE)
  language  String     @default("uz")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  merchant  Merchant?
  orders    Order[]   @relation("CustomerOrders")
  reviews   Review[]
  messages  ChatMessage[] @relation("MessageSender")

  @@index([role, status])
}

model Merchant {
  id          String   @id @default(uuid()) @db.Uuid
  ownerId     String   @unique @db.Uuid
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  logo        String?
  warehouseAddress String
  warehouseLat Float
  warehouseLng Float
  verifiedAt  DateTime?
  rating      Float    @default(0)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
  orders   Order[]
}

model Category {
  id       String    @id @default(uuid()) @db.Uuid
  slug     String    @unique
  nameUz   String
  nameRu   String
  icon     String?
  parentId String?   @db.Uuid
  parent   Category? @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryParent")

  products Product[]
}

model Product {
  id           String    @id @default(uuid()) @db.Uuid
  merchantId   String    @db.Uuid
  merchant     Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  categoryId   String    @db.Uuid
  category     Category  @relation(fields: [categoryId], references: [id])
  nameUz       String
  nameRu       String
  descriptionUz String?
  descriptionRu String?
  price        Float
  currency     String    @default("UZS")
  unit         String    // ton, m3, dona, kg, ...
  bodyKind     String?   // suggested vehicle body kind for delivery
  weightPerUnitKg Float? // helpful for cargo spec
  stock        Float     @default(0)
  photos       String[]  @default([])
  active       Boolean   @default(true)
  rating       Float     @default(0)
  ratingCount  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orderItems OrderItem[]
  reviews    Review[]

  @@index([merchantId, active])
  @@index([categoryId, active])
}

model Order {
  id           String      @id @default(uuid()) @db.Uuid
  customerId   String      @db.Uuid
  customer     User        @relation("CustomerOrders", fields: [customerId], references: [id])
  merchantId   String      @db.Uuid
  merchant     Merchant    @relation(fields: [merchantId], references: [id])
  status       OrderStatus @default(CREATED)

  deliveryAddress String
  deliveryLat     Float
  deliveryLng     Float
  scheduledAt     DateTime?

  totalAmount  Float
  currency     String      @default("UZS")

  /// Set after TransCargo matches a driver via cargo_request.matched event.
  cargoRequestId String?   @db.Uuid
  driverName    String?
  driverPhone   String?
  vehiclePlate  String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  confirmedAt  DateTime?
  deliveredAt  DateTime?

  items    OrderItem[]
  payments Payment[]
  messages ChatMessage[]

  @@index([status])
  @@index([customerId])
  @@index([merchantId])
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @db.Uuid
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id])
  quantity  Float
  unitPrice Float
  unit      String
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  authorId  String   @db.Uuid
  author    User     @relation(fields: [authorId], references: [id])
  stars     Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([productId, authorId])
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @db.Uuid
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderId  String   @db.Uuid
  sender    User     @relation("MessageSender", fields: [senderId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

enum PaymentProvider {
  CLICK
  PAYME
  UZUM
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Payment {
  id        String          @id @default(uuid()) @db.Uuid
  orderId   String          @db.Uuid
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider  PaymentProvider
  status    PaymentStatus   @default(PENDING)
  amount    Float
  currency  String          @default("UZS")
  externalId String?
  payloadJson Json?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([status])
}

model OutboxEvent {
  id          String    @id @default(uuid()) @db.Uuid
  routingKey  String
  payload     Json
  publishedAt DateTime?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([publishedAt])
}

model InboxEvent {
  eventId    String   @id @db.Uuid
  routingKey String
  receivedAt DateTime @default(now())
}
