{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "dist",
    "baseUrl": "./",
    "incremental": true,
    "noUncheckedIndexedAccess": false,
    "isolatedModules": false,
    "paths": { "@/*": ["src/*"] }
  },
  "include": ["src/**/*"]
}
