{
  "name": "@cargos/ui-kit",
  "version": "0.0.1",
  "private": true,
  "description": "Shared React + Tailwind UI components for admin dashboards.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tailwind-preset": "./tailwind-preset.cjs"
  },
  "files": ["dist", "tailwind-preset.cjs"],
  "scripts": {
    "build": "tsup src/index.tsx --format cjs,esm --dts --clean --external react",
    "dev": "tsup src/index.tsx --format cjs,esm --dts --watch --external react",
    "lint": "eslint src",
    "test": "echo \"(no tests yet)\""
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
